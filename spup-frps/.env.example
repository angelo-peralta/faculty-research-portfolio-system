# App
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.0.0
NEXT_PUBLIC_APP_BUILD_ID=local

# Microsoft Entra ID authentication
AZURE_AD_CLIENT_ID=your-application-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
# Use the Directory (tenant) ID for a single-tenant app.
# For a multi-tenant work/school app, use organizations.
# For work/school plus personal Microsoft accounts, use common.
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/callback

# Database
DATABASE_URL=mysql://frp_user:frp_password@127.0.0.1:3306/frp
MYSQL_CONNECTION_LIMIT=10

# Initial admin seeding
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NAME="Main Administrator"

# Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# Distributed rate limiting
# Optional. If unset, API rate limits fall back to a process-local development limiter.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Publication lookup
OPENALEX_API_BASE_URL=https://api.openalex.org

# One-time Supabase -> MySQL import.
# Prefer putting these in .env.import.local instead of app runtime env files.
# SOURCE_SUPABASE_URL=https://your-project-ref.supabase.co
# SOURCE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
